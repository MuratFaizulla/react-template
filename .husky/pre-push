#!/bin/sh
# Blocks direct pushes to main — use a feature branch and open a PR instead.

protected_branch="main"
current_branch=$(git symbolic-ref HEAD | sed 's|refs/heads/||')

if [ "$current_branch" != "$protected_branch" ]; then
  exit 0
fi

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$local_sha" = "0000000000000000000000000000000000000000" ]; then
    continue
  fi
  if echo "$remote_ref" | grep -q "refs/heads/$protected_branch"; then
    echo ""
    echo "  Direct push to '$protected_branch' is not allowed."
    echo "  Create a feature branch and open a PR:"
    echo ""
    echo "    git checkout -b feat/your-branch-name"
    echo "    git push origin feat/your-branch-name"
    echo ""
    exit 1
  fi
done

exit 0
